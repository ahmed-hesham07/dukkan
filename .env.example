# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=dukkan
POSTGRES_PASSWORD=dukkan_secret
POSTGRES_DB=dukkan
POSTGRES_PORT=5847

# ─── Backend ───────────────────────────────────────────────────────────────────
# Used inside Docker (service name "db" resolves to container)
DATABASE_URL=postgresql://dukkan:dukkan_secret@db:5432/dukkan
# Used for local dev (connecting from host machine)
DATABASE_URL_LOCAL=postgresql://dukkan:dukkan_secret@localhost:5847/dukkan
PORT=4847
NODE_ENV=development
CORS_ORIGIN=http://localhost:3847

# ─── Frontend (Vite build-time) ────────────────────────────────────────────────
VITE_API_URL=http://localhost:4847/api/v1
